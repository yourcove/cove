{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cove": {
    "CovePaths": [],
    "GeneratedPath": "./generated",
    "CachePath": "./cache",
    "Host": "0.0.0.0",
    "Port": 9999,
    "MaxParallelTasks": 1,
    "CalculateMd5": false,
    "Auth": {
      "Enabled": false,
      "JwtSecret": "CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS",
      "MaxSessionAgeMinutes": 10080
    },
    "Postgres": {
      "Managed": true,
      "Port": 5433,
      "Database": "cove"
    }
  }
}
